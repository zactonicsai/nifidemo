# =============================================================================
# FreshMart Demo — Environment Overrides
# Copy this to .env and edit. Most defaults are fine for local demo use.
# =============================================================================

# NiFi
NIFI_USER=admin
NIFI_PASSWORD=FreshMart2024Secret!

# PostgreSQL
POSTGRES_DB=freshmart_dw
POSTGRES_USER=nifi
POSTGRES_PASSWORD=nifi_secret

# AWS / LocalStack
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# Ports — override if any clash on your host
DASHBOARD_PORT=8000
NIFI_PORT=8443
KAFKA_PORT=9092
KAFKA_UI_PORT=8081
PGADMIN_PORT=8082
LOCALSTACK_PORT=4566
POS_SIM_PORT=9090
VALIDATOR_PORT=8080
